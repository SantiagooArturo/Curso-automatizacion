# ---- Firebase Web (client) config — public, safe to expose in the browser ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server) credential — SECRET, never expose to the client ----
# Local dev: drop the service-account JSON at ./firebase-service-account.json (gitignored).
# Production (Vercel): set ONE of the following instead of the file:
#   FIREBASE_SERVICE_ACCOUNT_B64  = base64 of the service-account JSON (recommended)
#   FIREBASE_SERVICE_ACCOUNT      = the raw service-account JSON string
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_B64=
